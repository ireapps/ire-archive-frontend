# IRE Archive Frontend — Environment Variables
# Copy this file to .env.development for local development.
# Never commit .env files containing real secrets.

# =============================================================================
# REQUIRED
# =============================================================================

# URL of the compatible FastAPI backend.
# For local development, point at the backend running on your machine.
# For production, point at your deployed backend.
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# OPTIONAL — SITE BRANDING
# =============================================================================

# Site title shown in <title> and Open Graph tags.
# Default: "Archive Search"
# VITE_SITE_TITLE=Archive Search

# Site description shown in meta and Open Graph tags.
# Default: "Search thousands of tipsheets, transcripts and training materials"
# VITE_SITE_DESCRIPTION=Search thousands of tipsheets, transcripts and training materials

# Path to the OG image (relative to /static, or an absolute URL).
# Default: "/logo.png"  (the generic placeholder bundled with the repo)
# IRE production uses "/ire-logo.png" via .env.production.
# VITE_SITE_IMAGE=/logo.png

# Valid resource categories as a JSON array.
# Defaults to IRE's document types: ["audio","contest entry","dataset","journal","tipsheet","webinar"]
# Override to match your own backend's category list.
# VITE_CATEGORIES=["audio","tipsheet","webinar","dataset"]

# =============================================================================
# OPTIONAL — DEVELOPMENT / TESTING
# =============================================================================

# Set to "true" to bypass authentication entirely.
# When enabled, the frontend uses built-in mock data and never calls the backend.
# Useful for UI development without a running backend, and for CI E2E tests.
# NEVER set this to "true" in a production deployment.
VITE_AUTH_BYPASS=false
