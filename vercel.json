{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "regions": ["iad1"],
  "rewrites": [
    { "source": "/api/:path*", "destination": "$BACKEND_URL/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
